# Voice Keyboard Agent — dotenv 配置（参考 transmission_assistant 项目的配置模式）
#
# 复制为 .env 并填入你的 API Key。
# .env 会被 config.py 自动加载，无需修改代码。
# .env 文件已在 .gitignore 中，不会被提交到 git。
#
# 注意：config.yaml 优先级高于 .env；若已有 config.yaml 则以其为准。

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 智谱 AI（zhipuai provider）
# GLM_API_KEY 同时用于 STT 和 LLM，填一个 key 即可
# 与 transmission_assistant 项目命名保持一致
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
GLM_API_KEY=your_zhipuai_api_key_here
# GLM_MODEL=glm-4-flash          # LLM 模型，默认 glm-4-flash
# STT_MODEL=glm-4-voice          # STT 模型，默认 glm-4-voice

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 显式指定 provider（可省略，GLM_API_KEY 存在时自动推断为 zhipuai）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# STT_PROVIDER=zhipuai
# LLM_PROVIDER=zhipuai

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI 键专用 STT：GLM-ASR-2512（可选）
# 普通听写继续走 STT_PROVIDER；按住 AI 键时走这里。
# 若已填写 GLM_API_KEY，可省略 AI_STT_API_KEY。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI_STT_PROVIDER=glm_asr_2512
# AI_STT_API_KEY=your_zhipuai_api_key_here
# AI_STT_MODEL=glm-asr-2512
# AI_STT_HOTWORDS=Voice Keyboard,备忘录,撤回

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OpenAI（openai provider）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# STT_PROVIDER=openai
# STT_API_KEY=sk-...
# STT_MODEL=whisper-1
# STT_LANGUAGE=zh
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 阿里云（aliyun provider）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# STT_PROVIDER=aliyun
# STT_ACCESS_KEY_ID=LTAI5t...
# STT_ACCESS_KEY_SECRET=...
# STT_APP_KEY=...
# STT_REGION=cn-shanghai
# STT_LANGUAGE=zh

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 火山引擎（volcengine provider）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# STT_PROVIDER=volcengine
# STT_APP_ID=...
# STT_TOKEN=...
# STT_CLUSTER=volcengine_streaming_common
# STT_LANGUAGE=zh-CN

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 音频设置（可选，未填则用 config.yaml 或内置默认值）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AUDIO_MODE=ptt              # ptt 或 vad
# PTT_KEY=right_alt
# EDIT_KEY=right_ctrl
# AUDIO_DEVICE=auto
# VAD_AGGRESSIVENESS=2
